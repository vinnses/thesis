# Copy this file to .env and adjust values as needed.

# Container user identity (used for build and runtime user mapping).
TEXUSER=texuser
TEXUID=1000
TEXGID=1000

# Optional Compose project name.
# If unset, Compose usually derives it from the directory name.
# The container hostname follows this value.
# COMPOSE_PROJECT_NAME=template-latex-docker

# Docker build target:
# - minimal: installs scheme-basic and latexmk; latexctl resolves project packages
# - full: installs an upstream TeX Live full scheme
TEXLIVE=minimal

# Optional explicit CTAN tlnet repository for both image build and runtime tlmgr operations.
# Leave empty to use the first mirror supplied by standalone latexctl.
# CTAN_MIRROR=https://ctan.math.illinois.edu/systems/texlive/tlnet

# Standalone latexctl source. The defaults track the public main branch.
# LATEXCTL_REPOSITORY=https://github.com/vinnses/latexctl.git
# LATEXCTL_REF=main

# Project template URL.
# Leave empty to let latexctl bootstrap tex/ from its default scaffold.
# Set TEMPLATE_URL only to override that scaffold with a git/zip/tar source.
TEMPLATE_URL=https://git.c3sl.ufpr.br/maziero/tese.git
